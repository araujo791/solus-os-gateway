# Maintainer: MachCtrl <noreply@machctrl.local>
pkgname=machctrl
pkgver=1.0.0
pkgrel=1
pkgdesc="MachCtrl - Monitor de hardware estilo MachCtrl 2.0 para CachyOS/Arch"
arch=('x86_64')
url="https://github.com/araujo791/solus-os-gateway"
license=('MIT')
depends=('lm_sensors' 'python' 'python-psutil' 'dmidecode' 'fuse2')
makedepends=('nodejs' 'npm')
options=(!strip !debug)
source=("MachCtrl-x86_64.AppImage" "machctrl.desktop" "machctrl.png")
sha256sums=('SKIP' 'SKIP' 'SKIP')

package() {
  install -Dm755 "$srcdir/MachCtrl-x86_64.AppImage" "$pkgdir/opt/machctrl/MachCtrl.AppImage"
  install -Dm644 "$srcdir/machctrl.desktop" "$pkgdir/usr/share/applications/machctrl.desktop"
  install -Dm644 "$srcdir/machctrl.png" "$pkgdir/usr/share/icons/hicolor/512x512/apps/machctrl.png"

  install -dm755 "$pkgdir/usr/bin"
  cat > "$pkgdir/usr/bin/machctrl" <<'EOF'
#!/usr/bin/env bash
exec /opt/machctrl/MachCtrl.AppImage "$@"
EOF
  chmod 755 "$pkgdir/usr/bin/machctrl"
}
